{
  "name": "repoflow",
  "displayName": "RepoFlow — Git Tools & Graph",
  "description": "Interactive Git graph, commit history, diff, stash, blame, worktree manager and pull request manager for Visual Studio Code.",
  "version": "1.2.6",
  "publisher": "farigab",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0D1117",
    "theme": "dark"
  },
  "type": "commonjs",
  "engines": {
    "vscode": ">=1.105.1"
  },
  "categories": [
    "SCM Providers",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "git",
    "graph",
    "commits",
    "history",
    "diff",
    "branches",
    "worktree"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "RepoFlow",
      "properties": {
        "repoFlow.autoFetch.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically fetch remote refs while the VS Code window is focused so RepoFlow can detect incoming commits."
        },
        "repoFlow.autoFetch.intervalSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 30,
          "description": "Seconds between automatic fetch checks while RepoFlow is active. Values below 30 are clamped to 30."
        }
      }
    },
    "views": {
      "scm": [
        {
          "id": "repoFlow.branchesView",
          "name": "Branches",
          "when": "gitOpenRepositoryCount != 0"
        }
      ]
    },
    "commands": [
      {
        "command": "repoFlow.openView",
        "title": "RepoFlow: Open Graph",
        "icon": "$(git-branch)"
      },
      {
        "command": "repoFlow.refresh",
        "title": "RepoFlow: Refresh"
      },
      {
        "command": "repoFlow.fetch",
        "title": "RepoFlow: Fetch"
      },
      {
        "command": "repoFlow.pull",
        "title": "RepoFlow: Pull"
      },
      {
        "command": "repoFlow.push",
        "title": "RepoFlow: Push"
      },
      {
        "command": "repoFlow.createBranch",
        "title": "RepoFlow: Create Branch",
        "icon": "$(add)"
      },
      {
        "command": "repoFlow.commitChanges",
        "title": "RepoFlow: Commit Changes",
        "icon": "$(check)"
      },
      {
        "command": "repoFlow.compareBranches",
        "title": "RepoFlow: Compare Branches"
      },
      {
        "command": "repoFlow.undoLastOperation",
        "title": "RepoFlow: Undo Last Operation"
      },
      {
        "command": "repoFlow.branches.refresh",
        "title": "Refresh Branches",
        "icon": "$(refresh)"
      },
      {
        "command": "repoFlow.branches.checkout",
        "title": "Checkout Branch",
        "icon": "$(arrow-right)"
      },
      {
        "command": "repoFlow.branches.delete",
        "title": "Delete Branch",
        "icon": "$(trash)"
      },
      {
        "command": "repoFlow.branches.merge",
        "title": "Merge Branch into Current",
        "icon": "$(git-merge)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "repoFlow.openView",
          "when": "scmProvider == git",
          "group": "navigation@2"
        },
        {
          "command": "repoFlow.createBranch",
          "when": "scmProvider == git",
          "group": "navigation@3"
        }
      ],
      "view/title": [
        {
          "command": "repoFlow.refresh",
          "when": "view == repoFlow.graphView",
          "group": "navigation"
        },
        {
          "command": "repoFlow.fetch",
          "when": "view == repoFlow.graphView",
          "group": "navigation@1"
        },
        {
          "command": "repoFlow.branches.refresh",
          "when": "view == repoFlow.branchesView",
          "group": "navigation"
        },
        {
          "command": "repoFlow.createBranch",
          "when": "view == repoFlow.branchesView",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "repoFlow.branches.checkout",
          "when": "view == repoFlow.branchesView && viewItem == branch",
          "group": "inline@1"
        },
        {
          "command": "repoFlow.branches.delete",
          "when": "view == repoFlow.branchesView && viewItem == branch",
          "group": "inline@2"
        },
        {
          "command": "repoFlow.branches.checkout",
          "when": "view == repoFlow.branchesView && viewItem == branch",
          "group": "1_actions@1"
        },
        {
          "command": "repoFlow.branches.merge",
          "when": "view == repoFlow.branchesView && viewItem == branch",
          "group": "1_actions@2"
        },
        {
          "command": "repoFlow.branches.delete",
          "when": "view == repoFlow.branchesView && viewItem == branch",
          "group": "2_destructive@1"
        }
      ],
      "commandPalette": [
        {
          "command": "repoFlow.openView"
        },
        {
          "command": "repoFlow.refresh"
        },
        {
          "command": "repoFlow.fetch"
        },
        {
          "command": "repoFlow.pull"
        },
        {
          "command": "repoFlow.push"
        },
        {
          "command": "repoFlow.createBranch"
        },
        {
          "command": "repoFlow.commitChanges"
        },
        {
          "command": "repoFlow.compareBranches"
        },
        {
          "command": "repoFlow.undoLastOperation"
        },
        {
          "command": "repoFlow.branches.refresh",
          "when": "false"
        },
        {
          "command": "repoFlow.branches.checkout",
          "when": "false"
        },
        {
          "command": "repoFlow.branches.delete",
          "when": "false"
        },
        {
          "command": "repoFlow.branches.merge",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "build": "node ./esbuild.mjs",
    "compile": "npm run build",
    "watch": "node ./esbuild.mjs --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "pretest": "tsc -p ./tsconfig.json --outDir out-test",
    "test": "node --test out-test/src/test/buildGraphRows.test.js out-test/src/test/gitParsers.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/farigab/repoFlow"
  },
  "bugs": {
    "url": "https://github.com/farigab/repoFlow/issues"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
