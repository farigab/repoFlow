{
  "name": "gitgraphor",
  "displayName": "Git Graphor",
  "description": "Interactive Git graph explorer for Visual Studio Code with native diff integration.",
  "version": "1.1.8",
  "publisher": "farigab",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0D1117",
    "theme": "dark"
  },
  "type": "commonjs",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "SCM Providers",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "git",
    "graph",
    "commits",
    "history",
    "diff",
    "branches"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitGraphor.openView",
        "title": "Git Graphor: Open Graph",
        "icon": {
          "light": "media/icon-mono-light.svg",
          "dark": "media/icon-mono.svg"
        }
      },
      {
        "command": "gitGraphor.refresh",
        "title": "Git Graphor: Refresh"
      },
      {
        "command": "gitGraphor.fetch",
        "title": "Git Graphor: Fetch"
      },
      {
        "command": "gitGraphor.pull",
        "title": "Git Graphor: Pull"
      },
      {
        "command": "gitGraphor.push",
        "title": "Git Graphor: Push"
      },
      {
        "command": "gitGraphor.createBranch",
        "title": "Git Graphor: Create Branch"
      },
      {
        "command": "gitGraphor.commitChanges",
        "title": "Git Graphor: Commit Changes"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "gitGraphor.openView",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "gitGraphor.refresh",
          "when": "view == gitGraphor.graphView",
          "group": "navigation"
        },
        {
          "command": "gitGraphor.fetch",
          "when": "view == gitGraphor.graphView",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "gitGraphor.openView"
        },
        {
          "command": "gitGraphor.refresh"
        },
        {
          "command": "gitGraphor.fetch"
        },
        {
          "command": "gitGraphor.pull"
        },
        {
          "command": "gitGraphor.push"
        },
        {
          "command": "gitGraphor.createBranch"
        },
        {
          "command": "gitGraphor.commitChanges"
        }
      ]
    }
  },
  "scripts": {
    "build": "node ./esbuild.mjs",
    "compile": "npm run build",
    "watch": "node ./esbuild.mjs --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "pretest": "tsc -p ./tsconfig.json --outDir out-test",
    "test": "node --test out-test/src/test/buildGraphRows.test.js out-test/src/test/gitParsers.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/farigab/gitgraphor"
  },
  "bugs": {
    "url": "https://github.com/farigab/gitgraphor/issues"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
